; Engine configuration file.
; It's best edited using the editor, not directly,
; but this starter is enough to launch and iterate.

config_version=4

[application]
config/name="Luo World"
run/main_scene="res://scenes/Main.tscn"
config/icon="res://assets/icon.png"

[display]
window/size/width=1280
window/size/height=720
window/handheld/orientation="landscape"
window/stretch/mode="2d"
window/stretch/aspect="expand"

[rendering]
quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_environment="res://assets/default_env.tres"

[autoload]
Items="*res://scripts/Items.gd"
GameState="*res://scripts/GameState.gd"
